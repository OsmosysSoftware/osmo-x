{
  "name": "osmox-portal",
  "version": "8.1.0",
  "description": "OsmoX notification management portal",
  "author": "Osmosys",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint . --max-warnings=0 --ignore-pattern '.angular/**'",
    "build:prod": "ng build --configuration production",
    "lint:fix": "eslint . --fix --ignore-pattern '.angular/**'",
    "prettier-format": "prettier --write \"**/*.{js,ts,html,scss,json}\"",
    "lint-fix-format": "npm run prettier-format && npm run lint:fix && npm run prettier-format",
    "generate:api": "openapi-typescript http://localhost:3000/api/docs-json -o src/app/core/types/api.types.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "prettier --write"
    ],
    "*.{js,scss,json}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@primeuix/themes": "^1.2.5",
    "chart.js": "^4.5.1",
    "openapi-fetch": "^0.15.0",
    "postcss": "^8.5.6",
    "primeicons": "^7.0.0",
    "primeng": "^20.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.8",
    "@angular/cli": "^20.3.8",
    "@angular/compiler-cli": "^20.3.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "20.5.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.2.6",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.16",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.1"
  }
}
